# SpeakCoach — Mobile environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# API base URL — used by src/services/api.ts
# Defaults to the deployed Fly.io API if unset.
EXPO_PUBLIC_API_BASE=https://talk-to-anybody-api.fly.dev/api/v1

# (Optional) RevenueCat public SDK key — only used in apps/mobile when wiring
# real subscriptions. Leave blank to fall back to the dev "always paid" path.
# Note: the RevenueCat public key is safe to ship in the client.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
