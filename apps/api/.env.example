PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5432/speakcoach

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=30

# Storage (S3-compatible)
BUCKET_NAME=speakcoach-recordings
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=

# Jobs
REDIS_URL=redis://localhost:6379

# AI providers
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Purchase verification
# Required in production. Get from https://app.revenuecat.com -> Project -> API keys -> Secret API Key
REVENUECAT_SECRET_API_KEY=
# Dev-only escape hatch. NEVER set to 'true' in production.
ALLOW_UNVERIFIED_PURCHASES=false
